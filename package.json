{
  "name": "opra",
  "description": "Open Protocol for Restful Api",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/panates/opra.git"
  },
  "workspaces": [
    "packages/*",
    "examples/_lib/*",
    "examples/*"
  ],
  "scripts": {
    "preclean": "rimraf build coverage",
    "clean": "rman run clean",
    "build": "rman build",
    "test": "tsc -b tsconfig-test.json --noEmit && mocha",
    "precover": "rimraf coverage",
    "format": "prettier . --write --log-level=warn",
    "precitest": "rimraf coverage reports",
    "citest": "c8 mocha",
    "qc": "rman run lint && rman run check",
    "lint": "rman run lint",
    "lint:fix": "rman run lint:fix",
    "check": "rman run check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@panates/eslint-config": "^2.1.6",
    "@panates/eslint-config-ts": "^2.1.6",
    "@panates/tsconfig": "^2.1.6",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "^0.5.21",
    "@swc-node/register": "^1.11.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.7.0",
    "@types/sinon": "^21.0.1",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "chalk": "^5.6.2",
    "esbuild": "^0.28.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "dpdm": "^4.2.0",
    "mocha": "^11.7.5",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3",
    "putil-varhelpers": "^1.7.0",
    "rimraf": "^6.1.3",
    "ts-cleanup": "^1.3.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
